# services/api_client.py

import httpx

API_BASE = "http://localhost:8000"

def get_rota_via_api(empresa, instalacao, max_os, token):
    r = httpx.get(
        f"{API_BASE}/rota",
        params={"empresa": empresa, "instalacao": instalacao,
                "max_os": max_os, "token": token},
        timeout=30,
    )
    r.raise_for_status()
    return r.json()
